{
  "name": "swarmtrade-registry",
  "region": "sfo",
  "services": [
    {
      "name": "registry-api",
      "github": {
        "repo": "tjcrowley/a2a-hub",
        "branch": "main",
        "deploy_on_push": true
      },
      "dockerfile_path": "Dockerfile",
      "instance_size_slug": "basic-xs",
      "instance_count": 1,
      "http_port": 8080,
      "envs": [
        {
          "key": "DATABASE_URL",
          "value": "${DATABASE_URL}",
          "scope": "RUN_AND_BUILD_TIME"
        },
        {
          "key": "DATABASE_CA_CERT",
          "value": "${DATABASE_CA_CERT}",
          "scope": "RUN_AND_BUILD_TIME"
        },
        {
          "key": "ADMIN_API_KEY",
          "value": "${ADMIN_API_KEY}",
          "scope": "RUN_AND_BUILD_TIME"
        },
        {
          "key": "CI",
          "value": "true",
          "scope": "BUILD_TIME"
        },
        {
          "key": "PNPM_CONFIG_CI",
          "value": "true",
          "scope": "BUILD_TIME"
        },
        {
          "key": "PNPM_CONFIG_CONFIRM_MODULES_PURGE",
          "value": "false",
          "scope": "BUILD_TIME"
        }
      ]
    }
  ],
  "static_sites": [
    {
      "name": "landing-page",
      "github": {
        "repo": "tjcrowley/a2a-hub",
        "branch": "main",
        "deploy_on_push": true
      },
      "source_dir": "public",
      "catchall_document": "index.html"
    }
  ],
  "domains": [
    {
      "domain": "swarmtrade.store",
      "type": "PRIMARY"
    }
  ],
  "ingress": {
    "rules": [
      {
        "match": {
          "path": {
            "prefix": "/admin"
          }
        },
        "component": {
          "name": "registry-api"
        }
      },
      {
        "match": {
          "path": {
            "prefix": "/registry"
          }
        },
        "component": {
          "name": "registry-api"
        }
      },
      {
        "match": {
          "path": {
            "prefix": "/negotiate"
          }
        },
        "component": {
          "name": "registry-api"
        }
      },
      {
        "match": {
          "path": {
            "prefix": "/health"
          }
        },
        "component": {
          "name": "registry-api"
        }
      },
      {
        "match": {
          "path": {
            "prefix": "/docs"
          }
        },
        "component": {
          "name": "registry-api"
        }
      },
      {
        "match": {
          "path": {
            "prefix": "/openapi"
          }
        },
        "component": {
          "name": "registry-api"
        }
      },
      {
        "match": {
          "path": {
            "prefix": "/"
          }
        },
        "component": {
          "name": "landing-page"
        }
      }
    ]
  }
}
